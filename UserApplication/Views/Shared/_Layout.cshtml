<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UserApplication</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 16.6667%;
            height: 100vh;
            background-color: #2c3e50;
            padding: 20px;
            overflow-y: auto;
        }

        .content-area {
            margin-left: 16.6667%;
            padding: 20px;
        }

        footer {
            margin-left: 16.6667%;
            padding: 10px 20px;
        }
    </style>

</head>
@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<body>

<div class="container-fluid">
    <div class="row">

            <div class="sidebar">
                <h1 style="color:whitesmoke">UserApp</h1>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Dashboard" && currentAction == "ViewDashboard" ? "active" : "")"
                           asp-controller="Dashboard"
                           asp-action="ViewDashboard">
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "User" && currentAction == "ViewAllUsers" ? "active" : "")"
                           asp-controller="User"
                           asp-action="ViewAllUsers">
                            User List
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Authentication" && currentAction == "Register" ? "active" : "")"
                           asp-controller="Authentication"
                           asp-action="Register">
                          Create User
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Authentication" && currentAction == "Logout" ? "active" : "")"
                           asp-controller="Authentication"
                           asp-action="Logout">
                          Signout
                        </a>
                    </li>
                </ul>

               
            </div>

            <div class="content-area">
                @RenderBody()
            </div>

            <footer class="border-top footer text-muted">
                <div class="container">
                    &copy; 2026 - UserApplication
                </div>
            </footer>
        

    </div>


<
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>